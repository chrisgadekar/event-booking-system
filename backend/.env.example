# Server
PORT=5000

# Database
# The bundled docker-compose runs a single-node replica set (enables
# transactions); directConnection keeps the driver pointed at it directly.
# A plain standalone MongoDB also works — the API falls back automatically.
MONGO_URI=mongodb://127.0.0.1:27017/sortmyscene?directConnection=true

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Reservation hold window (minutes)
RESERVATION_MINUTES=10

# Frontend origin allowed by CORS
CLIENT_ORIGIN=http://localhost:5173
